<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gameLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/football_pitch">

    <LinearLayout
        android:id="@+id/livesLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="@dimen/screen_margin"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/life1"
            android:layout_width="@dimen/life_ball_size"
            android:layout_height="@dimen/life_ball_size"
            android:src="@drawable/football_ball" />

        <ImageView
            android:id="@+id/life2"
            android:layout_width="@dimen/life_ball_size"
            android:layout_height="@dimen/life_ball_size"
            android:layout_marginStart="@dimen/life_spacing"
            android:src="@drawable/football_ball" />

        <ImageView
            android:id="@+id/life3"
            android:layout_width="@dimen/life_ball_size"
            android:layout_height="@dimen/life_ball_size"
            android:layout_marginStart="@dimen/life_spacing"
            android:src="@drawable/football_ball" />
    </LinearLayout>

    <ImageView
        android:id="@+id/player"
        android:layout_width="@dimen/arsenal_logo_width"
        android:layout_height="@dimen/arsenal_logo_height"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="120dp"
        android:src="@drawable/arsenal_logo"
        android:scaleType="fitCenter" />

    <ImageView
        android:id="@+id/leftButton"
        android:layout_width="@dimen/arrow_button_size"
        android:layout_height="@dimen/arrow_button_size"
        android:layout_gravity="bottom|start"
        android:layout_margin="24dp"
        android:src="@drawable/left_arrow"
        android:clickable="true"
        android:focusable="true" />

    <ImageView
        android:id="@+id/rightButton"
        android:layout_width="@dimen/arrow_button_size"
        android:layout_height="@dimen/arrow_button_size"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@drawable/right_arrow"
        android:clickable="true"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/gameOverLayout"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="#CC000000"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/game_over_message"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:gravity="center" />

        <Button
            android:id="@+id/startOverButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/start_over" />
    </LinearLayout>

</FrameLayout>